amends "package://github.com/jdx/hk/releases/download/v1.44.3/hk@1.44.3#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.44.3/hk@1.44.3#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  // Drift guard. `Directory.Build.props` is typically a `LastWorkingBuild` bump.
  // The `:guard` task regenerates `lib`, then asserts the working tree didn't
  // change; this is a fix-then-assert step deliberately wired into hk's `check`
  // slot so it blocks commits instead of silently auto-staging. On failure `lib`
  // is already dirty in the working tree (regenerated by the guard), so
  // just `git add lib && git commit`.
  ["refasm-libs"] {
    glob = List("Directory.Build.props")
    check = "mise run refasm-libs:guard"
  }

  ["csharpier"] {
    glob = List("*.cs")
    check = "csharpier check {{files}}"
    fix = "csharpier format {{files}}"
  }

  ["pkl_format"] = Builtins.pkl_format
  ["taplo_format"] = Builtins.taplo_format
  ["check_merge_conflict"] = Builtins.check_merge_conflict
  ["mixed_line_ending"] = Builtins.mixed_line_ending
  ["detect_private_key"] = Builtins.detect_private_key
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
